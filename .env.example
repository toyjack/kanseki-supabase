# PostgreSQLの検証用接続URL。実際の認証情報は.envだけに記載する。
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# SSHトンネルが必要な場合のみ使用する。
SSH_HOST=
SSH_LOCAL_PORT=15432

# self-hosted Supabaseのサーバー上の配置先。
SUPABASE_PATH=

# db-sparcから読み取るrsyncソースと、本サーバー上のローカルミラー。
RSYNC_SOURCE=USER@HOST:/path/to/data
RSYNC_DESTINATION=./data/rsync-mirror
